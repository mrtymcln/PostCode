        \cf6 // User types "100" (1 second), logic should handle it\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  framesSec = \cf11 TimecodeCalculator\cf4 .\cf12 inputToFrames\cf4 (\cf12 input\cf4 : \cf9 "100"\cf4 , \cf12 fps\cf4 : rate)\
        \cf8 #expect\cf4 (framesSec == \cf13 25\cf4 )\
    \}\
\}\
