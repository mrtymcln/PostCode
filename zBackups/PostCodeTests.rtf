\cf6 // Helper for comparing doubles (floating point math is rarely exact)\cf4 \

\f0\b \cf2 extension
\f1\b0 \cf4  \cf5 Double\cf4  \{\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 isApproximately\cf4 (\cf10 _\cf4  other: \cf14 Double\cf4 , \cf10 within\cf4  tolerance: \cf14 Double\cf4 ) -> \cf14 Bool\cf4  \{\
        
\f0\b \cf2 return
\f1\b0 \cf4  \cf8 abs\cf4 (
\f0\b \cf2 self
