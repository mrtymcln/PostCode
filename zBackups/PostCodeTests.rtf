\cf6 // 
\f0\b \cf7 MARK: - 1. FRAME RATE LOGIC AT 25 FPS
\f1\b0 \cf4 \
    \cf6 // Simple 1:1 math check.\cf4 \
    \cf8 @Test\cf4 (\cf9 "25 FPS: Basic Conversions"\cf4 )\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 test25fps\cf4 () \{\
        
\f0\b \cf2 let
\f1\b0 \cf4  rate = \cf11 FrameRate\cf4 .\cf12 fps25\cf4 \
        \
        \cf6 // 1 second exactly\cf4 \
        \cf8 #expect\cf4 (\cf11 TimecodeCalculator\cf4 .\cf12 framesToString\cf4 (\cf12 totalFrames\cf4 : \cf13 25\cf4 , \cf12 fps\cf4 : rate) == \cf9 "00:00:01:00"\cf4 )\
        \
        \cf6 // Round trip: String input -> Frames -> String output\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  inputFrames = \cf11 TimecodeCalculator\cf4 .\cf12 inputToFrames\cf4 (\cf12 input\cf4 : \cf9 "00000100"\cf4 , \cf12 fps\cf4 : rate)\
        \cf8 #expect\cf4 (inputFrames == \cf13 25\cf4 )\
    \}\
\
\cf6 // 
\f0\b \cf7 MARK: - 2. DROP FRAME LOGIC AT 29.97 FPS
\f1\b0 \cf4 \
    \cf6 // The most complex part of SMPTE. We test the "Minute boundaries".\cf4 \
    \cf8 @Test\cf4 (\cf9 "29.97 DF: Skips frames at Minute 1"\cf4 )\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 testDropFrameMinute1\cf4 () \{\
        
\f0\b \cf2 let
\f1\b0 \cf4  rate = \cf11 FrameRate\cf4 .\cf12 fps2997DF\cf4 \
        \
        \cf6 // Frame 1799 = 00:00:59;29 (Last frame of minute 0)\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  beforeSkip = \cf11 TimecodeCalculator\cf4 .\cf12 framesToString\cf4 (\cf12 totalFrames\cf4 : \cf13 1799\cf4 , \cf12 fps\cf4 : rate)\
        \cf8 #expect\cf4 (beforeSkip == \cf9 "00:00:59;29"\cf4 )\
        \
        \cf6 // Frame 1800 = 00:01:00;02 (First frame of minute 1)\cf4 \
        \cf6 // It MUST skip ;00 and ;01\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  afterSkip = \cf11 TimecodeCalculator\cf4 .\cf12 framesToString\cf4 (\cf12 totalFrames\cf4 : \cf13 1800\cf4 , \cf12 fps\cf4 : rate)\
        \cf8 #expect\cf4 (afterSkip == \cf9 "00:01:00;02"\cf4 )\
    \}\
\
    \cf8 @Test\cf4 (\cf9 "29.97 DF: Does NOT skip at Minute 10"\cf4 )\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 testDropFrameMinute10\cf4 () \{\
        
\f0\b \cf2 let
\f1\b0 \cf4  rate = \cf11 FrameRate\cf4 .\cf12 fps2997DF\cf4 \
        \
        \cf6 // 10 minutes = 17982 frames in Drop Frame\cf4 \
        \cf6 // It should NOT skip frames at the 10, 20, 30... minute marks.\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  tenMinutes = \cf11 TimecodeCalculator\cf4 .\cf12 framesToString\cf4 (\cf12 totalFrames\cf4 : \cf13 17982\cf4 , \cf12 fps\cf4 : rate)\
        \
        \cf6 // Should be exactly 00:10:00;00\cf4 \
        \cf8 #expect\cf4 (tenMinutes == \cf9 "00:10:00;00"\cf4 )\
    \}\
\
\cf6 // 
\f0\b \cf7 MARK: - 3. TIMECODE TO REAL TIME AT 23.976 FPS
\f1\b0 \cf4 \
    \cf6 // Verifies that timecode diverges from real-world seconds.\cf4 \
    \cf8 @Test\cf4 (\cf9 "23.976: Real Time Drift"\cf4 )\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 testNTSCRealTime\cf4 () \{\
        
\f0\b \cf2 let
\f1\b0 \cf4  rate = \cf11 FrameRate\cf4 .\cf12 fps23976\cf4 \
        \
        \cf6 // 1 Hour of Timecode (01:00:00:00) @ 24 base = 86400 frames\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  oneHourFrames = \cf13 86400\cf4 \
        \
        \cf6 // In the real world, 23.976 runs slower (0.1% slower).\cf4 \
        \cf6 // So 1 hour of TC takes 1 hour + 3.6 seconds of real time.\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  realSeconds = \cf11 TimecodeCalculator\cf4 .\cf12 framesToRealSeconds\cf4 (\cf12 totalFrames\cf4 : oneHourFrames, \cf12 fps\cf4 : rate)\
        \
        \cf6 // 3600 seconds * 1.001 = 3603.6 seconds\cf4 \
        \cf8 #expect\cf4 (realSeconds.\cf12 isApproximately\cf4 (\cf13 3603.6\cf4 , \cf12 within\cf4 : \cf13 0.001\cf4 ))\
    \}\
    \
\cf6 // 
\f0\b \cf7 MARK: - 4. ROUND TRIP & FORMATTING
\f1\b0 \cf4 \
    \cf8 @Test\cf4 (\cf9 "Formatting: Input Padding"\cf4 )\
    
\f0\b \cf2 func
\f1\b0 \cf4  \cf10 testInputPadding\cf4 () \{\
        
\f0\b \cf2 let
\f1\b0 \cf4  rate = \cf11 FrameRate\cf4 .\cf12 fps25\cf4 \
        \
        \cf6 // User types "1", logic should treat it as "00:00:00:01"\cf4 \
        
\f0\b \cf2 let
\f1\b0 \cf4  frames = \cf11 TimecodeCalculator\cf4 .\cf12 inputToFrames\cf4 (\cf12 input\cf4 : \cf9 "1"\cf4 , \cf12 fps\cf4 : rate)\
        \cf8 #expect\cf4 (frames == \cf13 1\cf4 )\
